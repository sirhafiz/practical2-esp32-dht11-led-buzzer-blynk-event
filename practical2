#define BLYNK_TEMPLATE_ID "MASUKKAN_TEMPLATE_ID_KAU"
#define BLYNK_TEMPLATE_NAME "DHT11 Alert LED Buzzer"
#define BLYNK_AUTH_TOKEN "MASUKKAN_AUTH_TOKEN_KAU"

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <DHT.h>

#define DHTPIN 4
#define DHTTYPE DHT11
#define LED_PIN 27
#define BUZZER_PIN 26

char ssid[] = "NAMA_WIFI_KAU";
char pass[] = "PASSWORD_WIFI_KAU";

DHT dht(DHTPIN, DHTTYPE);
bool temp_alert = false;   //elak spam notification

void setup() {
  Serial.begin(115200);     //set serial speed
  pinMode(LED_PIN, OUTPUT);    //set pin led as output
  pinMode(BUZZER_PIN, OUTPUT);    //set pin buzzer as output
  digitalWrite(LED_PIN, LOW);    //set led off pada permulaan
  digitalWrite(BUZZER_PIN, LOW);    //set buzzer off pada permulaan

  dht.begin();   //dht mula baca 
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);       //blynk membuat sahkan sambungan internet
  }

void loop() {
  Blynk.run();
  float suhu = dht.readTemperature();
  float lembap = dht.readHumidity();

  if (isnan(suhu) || isnan(lembap)) {
    Serial.println("Gagal baca DHT11!");
  } else {
    Serial.print("Suhu: "); 
    Serial.print(suhu);
    Serial.print(" °C | Kelembapan: "); 
    Serial.print(lembap);
    Serial.print(" % | Alert aktif: "); 
    Serial.println(temp_alert ? "YA" : "TIDAK");
  }

  Blynk.virtualWrite(V0, suhu);   //tulis suhu di blynk
  Blynk.virtualWrite(V1, lembap);  //tulis klembpan di blynk

  if (suhu > 30.0) { //jika suhu lebih 30
    digitalWrite(LED_PIN, HIGH);  //led on
    digitalWrite(BUZZER_PIN, HIGH);    //led on
    if (!temp_alert) {
      Blynk.logEvent("temp_high", String("SUHU PANAS! ") + suhu + " °C");
      Serial.println(">>> ALERT dihantar ke Blynk <<<");
      temp_alert = true;
    }
  } else {
    digitalWrite(LED_PIN, LOW);
    digitalWrite(BUZZER_PIN, LOW);
    if (temp_alert) {
       Blynk.logEvent("temp_low", String("SUHU normal! ") + suhu + " °C");
      Serial.println("Suhu dah turun → alert direset");
      temp_alert = false;
    }
  }
  delay(2000);
}
